PORT=4000
HOST=0.0.0.0

# Use Supabase pooler for serverless (port 6543) — required on Vercel
DATABASE_URL=postgresql://postgres.natlhzvunjrmuonusfdi:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://natlhzvunjrmuonusfdi.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Must include https:// — or just the project ref is auto-normalized
# Optional legacy fallback — JWKS (ES256 public keys) is used automatically when SUPABASE_URL is set
SUPABASE_JWT_SECRET=

# Comma-separated allowed frontend origins
CORS_ORIGIN=http://localhost:3000,https://slafrontend-web.vercel.app

# Optional — used in OpenAPI docs (defaults to VERCEL_URL on Vercel)
PUBLIC_URL=https://your-api.vercel.app
